{
  "name": "myblog",
  "version": "1.0.14",
  "private": true,
  "scripts": {
    "prepare": "node -e \"try{require('child_process').execSync('git rev-parse --git-dir',{stdio:'ignore'});require('child_process').execSync('git config core.hooksPath .githooks',{stdio:'inherit'})}catch(e){}\"",
    "build:prod": "node blogengine.mjs --open=false && npm run test",
    "build": "node blogengine.mjs",
    "serve": "node --watch-path=./src blogengine.mjs --open=true",
    "test": "jasmine",
    "docs:toc": "npx doctoc ./src/pages/2026/low-code-ui/index.md"
  },
  "dependencies": {
    "markdown-it": "14.1.0",
    "highlight.js": "11.10.0",
    "glob": "11.0.0",
    "open": "10.1.0",
    "minimist": "1.2.8",
    "jsdom": "26.0.0"
  },
  "devDependencies": {
    "jasmine": "5.6.0"
  }
}
